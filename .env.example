# X List ID (numeric, from the list URL: x.com/i/lists/<ID>)
SOCIALDATA_LIST_ID=

# SocialData API key (https://socialdata.tools/) - Bearer token
SOCIALDATA_API_KEY=

# Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# Telegram Bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send summaries AND error notifications to (same chat)
# Get yours from @userinfobot or by sending a message to your bot and querying getUpdates
TELEGRAM_CHAT_ID=

# Directory for the Tweet Store (date-scoped JSON files) and cursor.json
# Defaults to ./store relative to the working directory
STORE_DIR=./store
